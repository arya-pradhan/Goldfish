# Backend base URL.
# Local dev: http://localhost:3000  (use your LAN IP for a physical device, e.g. http://192.168.1.50:3000)
# Production: your Vercel deployment, e.g. https://goldfish-xxxx.vercel.app
EXPO_PUBLIC_API_URL=

# Mapbox public token (same token as the backend MAPBOX_TOKEN is fine).
# account.mapbox.com → Tokens
EXPO_PUBLIC_MAPBOX_TOKEN=

# Set true to fire the guilt-trip overlay immediately on app launch (demo without walking).
EXPO_PUBLIC_SIMULATE_HOTZONE=true
