# --- MongoDB Atlas (free M0 cluster) ---
# Atlas → Connect → Drivers → copy URI and insert your DB user password.
# Atlas → Network Access MUST allow 0.0.0.0/0 so Vercel can reach it.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/goldfish?retryWrites=true&w=majority

# --- Auth ---
# Any long random string. Generate: openssl rand -hex 32
JWT_SECRET=

# --- Plaid (sandbox) ---
# dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Mapbox (server-side geocoding fallback) ---
# account.mapbox.com → Tokens (the default public token works)
MAPBOX_TOKEN=
